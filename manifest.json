{
  "manifest_version": 3,
  "name": "Ymal Edu",
  "version": "2.1",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["*://*/*"],
  "background": { "service_worker": "background.js" },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
