{
  "manifest_version": 3,
  "name": "West Scranton Intermediate School Theme",
  "version": "1.0",
  "description": "Official Chrome theme for West Scranton Intermediate School",
  "theme": {
    "images": {
      "theme_frame": "images/school_logo.png"
    },
    "colors": {
      "frame": [0, 51, 160],
      "frame_inactive": [100, 100, 100],
      "frame_incognito": [0, 51, 160],
      "frame_incognito_inactive": [80, 80, 80],
      "toolbar": [255, 255, 255],
      "tab_text": [0, 51, 160],
      "tab_background_text": [255, 255, 255],
      "bookmark_text": [0, 51, 160],
      "ntp_background": [255, 255, 255],
      "ntp_text": [0, 51, 160],
      "button_background": [0, 51, 160, 0.1],
      "omnibox_text": [0, 0, 0],
      "omnibox_background": [255, 255, 255]
    },
    "tints": {
      "buttons": [0.6, 0.5, 0.8]
    },
    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_background_repeat": "no-repeat"
    }
  }
}
